# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dataset hasil ekstraksi landmark (besar, bisa diregenerasi)
/data/landmarks_*.json
/data/hand_landmarker.task

# SAPA: data mentah dan artefak training (regenerable, besar)
# Lihat data/README.md untuk cara regenerasi.
/data/*.json
!/data/word_labels.json
/data/*.task
/data/*.keras
/data/*.h5
/data/*.partial.json

# cache kagglehub lokal jika disalin ke repo
/scripts/__pycache__
